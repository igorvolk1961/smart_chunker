## Detailed Algorithm for `docx_table_to_simple_markdown`

```python
def docx_table_to_simple_markdown(self, docx_table, table_name) -> str:
    analysis = self.analyze_docx_table_structure(docx_table)
    column_attribute_rows = analysis["column_attribute_rows"]
    row_attribute_columns = analysis["row_attribute_columns"]
    
    # 1. Determine column names from header row
    header_row_idx = 0
    if column_attribute_rows:
        header_row_idx = min(column_attribute_rows)
    
    # First column name = item_name column (from row_attribute_columns)
    # For 2-col tables, first col is row header, so column name comes from header row cell[0]
    column_names: Dict[int, str] = {}
    for col_idx in range(docx_table.cols):
        if col_idx in row_attribute_columns:
            # This is a row header column — get its name from header row
            cell = docx_table.grid[header_row_idx][col_idx]
            column_names[col_idx] = cell.text.strip() if cell and cell.text else f"Колонка {col_idx + 1}"
        else:
            cell = docx_table.grid[header_row_idx][col_idx]
            column_names[col_idx] = cell.text.strip() if cell and cell.text else f"Колонка {col_idx + 1}"
    
    # 2. Build header row
    header_cells = [column_names.get(c, f"Колонка {c+1}") for c in range(docx_table.cols)]
    header = "| " + " | ".join(header_cells) + " |"
    
    # 3. Build separator
    separator = "|" + "|".join(["---"] * docx_table.cols) + "|"
    
    # 4. Build data rows
    rows = []
    for row_idx in range(docx_table.rows):
        if row_idx in column_attribute_rows:
            continue
        
        row_cells = []
        for col_idx in range(docx_table.cols):
            cell = docx_table.grid[row_idx][col_idx]
            if cell and cell.row == row_idx and cell.col == col_idx:
                row_cells.append(cell.text.strip() if cell.text else "")
            else:
                row_cells.append("")
        
        rows.append("| " + " | ".join(row_cells) + " |")
    
    # 5. Assemble
    table_str = f"# {table_name}\n\n{header}\n{separator}\n" + "\n".join(rows)
    return self._normalize_whitespace(table_str)
```

